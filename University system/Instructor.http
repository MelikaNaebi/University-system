POST {{host}}/api/Instructor/submit-grade
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..x9EKAsyZdQhMOxXTMNiH3RO1NVt786JcdAnCZJn3PqU
