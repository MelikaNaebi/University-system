### تنظیمات متغیرها
@hostname = localhost
@port = 7246
@host = https://{{hostname}}:{{port}}

### ۱. ورود به سیستم و گرفتن توکن
# @name LoginRequest
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "username": "admin2026",
  "password": "Password123!"
}

